PORT=3000
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=change-me-in-production
MONGO_URI=mongodb://localhost:27017/chat-mvp?replicaSet=rs0&directConnection=true

# LLM provider
OPENAI_API_KEY=your-openai-api-key
LLM_MODEL=gpt-4
LLM_MAX_TOKENS=1024

# Cheaper model used for non-streaming side tasks (title + rolling-summary compaction)
LLM_TITLE_MODEL=gpt-4o-mini
LLM_SUMMARY_MODEL=gpt-4o-mini

# Per-user assistant rate limit
ASSISTANT_RATE_BURST=5
ASSISTANT_RATE_REFILL_PER_SEC=0.5

# Assistant eval runner 
EVAL_THRESHOLD=0.7
